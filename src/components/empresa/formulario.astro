---
import type { Formulario } from "../../types/formulario";
import { getFormulario } from "../../utils/i18n/i18n";

const { lang } = Astro.params;
const currentLang = lang as "es" | "en";
const formData = await getFormulario(currentLang) as Formulario;
---

<section class="formulario">
  <div class="formulario-container">

    <span class="formulario-tag">{formData.header}</span>
    <h2>{formData.title}</h2>
    <h3>{formData.subtitle}</h3>

    <form id="contact-form" enctype="multipart/form-data">

      <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="form-group">
        <label>{formData.fields.subject}</label>
        <select id="subject-select" name="motivo" required>
          <option value="">--</option>
          {formData.options.map(option => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </div>

      <div class="form-group">
        <label>{formData.fields.name}</label>
        <input type="text" name="nombre" required />
      </div>

      <div class="form-group">
        <label>{formData.fields.company}</label>
        <input type="text" name="empresa" />
      </div>

      <div class="form-group">
        <label>{formData.fields.email}</label>
        <input type="email" name="email" required />
      </div>

      <div class="form-group">
        <label>{formData.fields.phone}</label>
        <input type="tel" name="telefono" />
      </div>

      <div class="form-group" id="cv-upload" style="display:none;">
        <label>{formData.fields.cv}</label>
        <input type="file" name="cv" accept=".pdf" />
      </div>

      <div class="form-group">
        <label>{formData.fields.message}</label>
        <textarea name="mensaje" rows="5" required></textarea>
      </div>

      <button type="submit" class="btn btn-primary">
        {formData.button}
      </button>

    </form>
  </div>
</section>
<!-- 
<script type="module" src="/src/scripts/contact-form.ts"></script> -->

<script type="module">
  // Define el toast aquí
  function showToast(message, type = "info", duration = 3000) {
    const container = document.getElementById("toast-container");
    if (!container) return;

    const toast = document.createElement("div");
    toast.classList.add("toast", type);
    toast.textContent = message;

    container.appendChild(toast);

    setTimeout(() => {
      toast.classList.add("hide");
      setTimeout(() => {
        toast.remove();
      }, 300);
    }, duration);
  }

  const initForm = () => {
    const form = document.querySelector("#contact-form");
    const select = document.querySelector("#subject-select");
    const upload = document.querySelector("#cv-upload");

    select?.addEventListener("change", (e) => {
      const target = e.target;
      if (upload) {
        upload.style.display = target.value === "cv" ? "block" : "none";
      }
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form) return;

      const formDataToSend = new FormData(form);

      showToast("Enviando mensaje...", "info");

      try {
        const res = await fetch("/api/send-contact", {
          method: "POST",
          body: formDataToSend,
        });

        const data = await res.json();

        if (res.ok) {
          showToast("✅ Mensaje enviado correctamente", "success");
          form.reset();
          if (upload) upload.style.display = "none";
        } else {
          showToast(data.error || "❌ Error enviando mensaje", "error");
        }
      } catch (error) {
        console.error("Error:", error);
        showToast("❌ Error de conexión", "error");
      }
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initForm);
  } else {
    initForm();
  }
</script>