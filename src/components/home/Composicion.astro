---

import type { Links } from "../../types/enlaces";

import { getLinks } from "../../utils/i18n/i18n";
import { buildUrl } from "../../utils/i18n/utils";

const { lang } = Astro.params;
const currentLang = lang as "es" | "en";

const linksData = await getLinks(currentLang) as Links;

const rawImages = import.meta.glob("/src/assets/empresa/*.{jpg,jpeg,png,webp}", {
  eager: true,
  as: "url"
});

const images = Object.fromEntries(
  Object.entries(rawImages).map(([path, url]) => {
    const name = path.replace(/^.*[\\/]/, "").replace(/\.[^/.]+$/, "");
    return [name, url];
  })
);

const links = linksData.links;
---

<section class="empresa-composition">
  <div class="container">
    <div class="fan-grid">

      {links.map((item, i) => {
        const total = links.length;
        const center = (total - 1) / 2;
        const offset = i - center;

        const rotation = offset * 3;
        const translateY = Math.abs(offset) * 5;
        const zIndex = total - Math.abs(offset);

        return (
          <a
            href={buildUrl(currentLang, item.url)}
            class="fan-item"
            style={`
              --rotate: ${rotation}deg;
              --offsetY: ${translateY}px;
              z-index: ${zIndex};
            `}
          >
            <img src={images[item.image]} alt={item.title} />

            <div class="fan-overlay">
              <span class="fan-title">{item.title}</span>
            </div>
          </a>
        );
      })}

    </div>
  </div>
</section>
