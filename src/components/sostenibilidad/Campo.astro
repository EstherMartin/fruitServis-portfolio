---
import type { CampoData } from "../../types/campo";
import { getCampo } from "../../utils/i18n/i18n";
import { Image } from "astro:assets";
import globalgap from "../../assets/certificados/globalgap.png";
import grasp from "../../assets/certificados/grasp.png";
import ifs from "../../assets/certificados/ifs.jpg";

const { lang } = Astro.params;
const currentLang = lang as "es" | "en";

const data = await getCampo(currentLang) as CampoData;

const rawImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/campo/*.{jpg,jpeg,png,webp}",
  { eager: true }
);

const images: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(rawImages).map(([path, module]) => {
    const name = path.replace(/^.*[\\/]/, "").replace(/\.[^/.]+$/, "");
    return [name, module.default];
  })
);
---

<section class="campo">

  <div class="campo-hero">
    <span class="campo-tag">{data.header}</span>
    <h1>{data.heroTitle}</h1>
    <p>{data.heroSubtitle}</p>
  </div>

  <div class="campo-sections">
    {data.sections.map((section, index) => {
      const imageSrc = images[section.image];
      const reverse = index % 2 !== 0;

      return (
        <div class={`campo-row ${reverse ? "reverse" : ""}`}>
          <div class="campo-text">
            <h2>{section.title}</h2>
            {section.text.map(p => <p>{p}</p>)}
          </div>

          <div class="campo-image">
            <Image src={imageSrc} alt={section.title} width={600} />
          </div>
        </div>
      );
    })}
  </div>

  <div class="campo-certificados">
    <div class="campo-hero">
      <span class="campo-tag">{data.certificationsTitle}</span>
    </div>
    <div class="certificados-grid">
      <Image src={globalgap} alt="Global GAP" width={120} />
      <Image src={grasp} alt="GRASP" width={120} />
      <Image src={ifs} alt="IFS" width={120} />
    </div>
  </div>
</section>