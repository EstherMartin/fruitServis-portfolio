---
import { detectBrowserLang } from "../utils/i18n/utils";
import { defaultLang } from "../utils/i18n/config";

const cookieLang = Astro.cookies.get("lang")?.value;

const browserLang = detectBrowserLang(
  Astro.request.headers.get("accept-language")
);

const lang = cookieLang ?? browserLang ?? defaultLang;

Astro.cookies.set("lang", lang, {
  path: "/",
  maxAge: 60 * 60 * 24 * 365 // 1 año
});

return Astro.redirect(`/${lang}`);
---