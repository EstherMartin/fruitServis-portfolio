---
import Layout from '../../layouts/Layout.astro';
import Header from "../../components/home/Header.astro";
import EmpresaHistoria from '../../components/home/Empresa-historia.astro';
import EmpresaDefinicion from '../../components/home/Empresa-definicion.astro';
import Composicion from '../../components/home/Composicion.astro';

export const prerender = false;

import { generateStaticPaths } from "../../utils/i18n/utils";
import { isValidLang, defaultLang } from "../../utils/i18n/config";

export const getStaticPaths = generateStaticPaths;

const { lang } = Astro.params;

if (!isValidLang(lang)) {
  return Astro.redirect(`/${defaultLang}`);
}

---

<Layout>
	<Header />
  <EmpresaDefinicion />
  <EmpresaHistoria />
  <Composicion />
</Layout>
