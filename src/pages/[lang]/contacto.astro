---
import NavBar from "../../components/NavBar.astro";
import ContactoInformacion from "../../components/empresa/contacto.astro";
import ContactoFormulario from "../../components/empresa/formulario.astro";
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';

import { generateStaticPaths } from "../../utils/i18n/utils";
import { isValidLang, defaultLang } from "../../utils/i18n/config";

export const getStaticPaths = generateStaticPaths;

const { lang } = Astro.params;

if (!isValidLang(lang)) {
  return Astro.redirect(`/${defaultLang}`);
}

---

<Layout>
	<NavBar />
  <ContactoFormulario />
  <ContactoInformacion />
  <Footer />
</Layout>

